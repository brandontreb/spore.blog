<!-- Author-->
<section id="post-meta" class="u-hidden p-author h-card">
  <a href="/" class="u-url">
  
  <% if(locals.user.profile_photo) { %>          
      <img class="u-photo avatar" src="<%- blog.url %>/<%- locals.user.profile_photo %>" alt="profile photo" width="100" height="100"/>                
  <% } else { %>
    <!-- load from gravatar-->          
      <img class="u-photo avatar" src="<%- locals.user.profile_photo_gravatar %>" alt="profile photo" width="100" height="100"/>          
  <% } %>
  
  <div>
    <span class="p-name dark"><%- locals.user.name %></span>
    <span><a href="<%- blog.url %>">@<%- locals.user.username %>@<%- locals.blog.bare_url %></a></span>
    <p class="p-note"><%- locals.user.about %></p>
  </div>

  </a>
</section>