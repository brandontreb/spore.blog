<div class="left p-author h-card">
  <a href="<%- locals.blog.url %>" class="u-url">
    <span class="p-name"><%- locals.user.full_name.length ? locals.user.full_name : locals.user.username %></span>
    <% if(locals.user.profile_photo) { %>
      <img class="u-photo avatar" src="<%- blog.url %>/<%- locals.user.profile_photo %>" width="100"
        height="100" />
    <% } else { %>
        <img class="u-photo avatar" src="<%- locals.user.profile_photo_gravatar %>" width="100"
          height="100" />
    <% } %>
    <p class="p-note"><%- locals.user.about %></p>
  </a>
</div>