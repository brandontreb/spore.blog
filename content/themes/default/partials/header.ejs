
  <nav class="row">    
    <a class="title" href="/">
    <span class="avatar">
    <% if(user.profile_photo) { %>          
      <img src="<%- blog.url %>/<%- user.profile_photo %>" alt="profile photo" width="100" height="100"/>                
    <% } else { %>
    <!-- load from gravatar-->          
      <img src="<%- user.profile_photo_gravatar %>" alt="profile photo" width="100" height="100"/>          
    <% } %>
    </span>    
      <h1>
        <%- blog.title %>
      </h1>
    </a>  
    <%- blog.nav_html %>
  </nav>
